{
  "name": "claude-chatgpt-image-mcp",
    "version": "1.0.0",
      "description": "Production MCP Server - Claude + ChatGPT + Advanced Image Processing",
        "tools": [
            {
                  "name": "analyze_image_with_claude",
                        "description": "Analyzes an image using Claude's vision capabilities",
                              "inputSchema": {
                                      "type": "object",
                                              "properties": {
                                                        "imagePath": {
                                                                    "type": "string",
                                                                                "description": "Path to the image file"
                                                                                          }
                                                                                                  },
                                                                                                          "required": ["imagePath"]
                                                                                                                }
                                                                                                                    },
                                                                                                                        {
                                                                                                                              "name": "analyze_image_with_chatgpt",
                                                                                                                                    "description": "Analyzes an image using ChatGPT's vision capabilities",
                                                                                                                                          "inputSchema": {
                                                                                                                                                  "type": "object",
                                                                                                                                                          "properties": {
                                                                                                                                                                    "imagePath": {
                                                                                                                                                                                "type": "string",
                                                                                                                                                                                            "description": "Path to the image file"
                                                                                                                                                                                                      }
                                                                                                                                                                                                              },
                                                                                                                                                                                                                      "required": ["imagePath"]
                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                    {
                                                                                                                                                                                                                                          "name": "extract_text_ocr",
                                                                                                                                                                                                                                                "description": "Extracts text from an image using OCR",
                                                                                                                                                                                                                                                      "inputSchema": {
                                                                                                                                                                                                                                                              "type": "object",
                                                                                                                                                                                                                                                                      "properties": {
                                                                                                                                                                                                                                                                                "imagePath": {
                                                                                                                                                                                                                                                                                            "type": "string",
                                                                                                                                                                                                                                                                                                        "description": "Path to the image file"
                                                                                                                                                                                                                                                                                                                  },
                                                                                                                                                                                                                                                                                                                            "language": {
                                                                                                                                                                                                                                                                                                                                        "type": "string",
                                                                                                                                                                                                                                                                                                                                                    "description": "OCR language (default: eng)"
                                                                                                                                                                                                                                                                                                                                                              }
                                                                                                                                                                                                                                                                                                                                                                      },
                                                                                                                                                                                                                                                                                                                                                                              "required": ["imagePath"]
                                                                                                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                                                                                                                                                  "name": "process_image",
                                                                                                                                                                                                                                                                                                                                                                                                        "description": "Processes an image (resize, convert format)",
                                                                                                                                                                                                                                                                                                                                                                                                              "inputSchema": {
                                                                                                                                                                                                                                                                                                                                                                                                                      "type": "object",
                                                                                                                                                                                                                                                                                                                                                                                                                              "properties": {
                                                                                                                                                                                                                                                                                                                                                                                                                                        "imagePath": {
                                                                                                                                                                                                                                                                                                                                                                                                                                                    "type": "string",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                "description": "Path to the image file"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                          },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    "format": {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "type": "string",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "enum": ["jpeg", "png", "webp"]
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "quality": {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "type": "number",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "description": "Quality level (1-100)"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  "required": ["imagePath"]
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              ],
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "capabilities": {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    "imageAnalysis": true,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "ocr": true,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "imageProcessing": true,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "multiModelSupport": true,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    "claudeIntegration": true,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "chatgptIntegration": true
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          }
